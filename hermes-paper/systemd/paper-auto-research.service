[Unit]
Description=TAN paper auto-research gate (paper-only)
After=paper.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/srv/hermes-os/paper
Environment=PYTHONIOENCODING=utf-8
Environment=PAPER_DATA_DIR=/srv/hermes-os/paper/data
Environment=PAPER_RESEARCH_OUTPUT=/srv/hermes-os/paper/data/paper_research_gate_latest.txt
Environment=PAPER_SEND_DISCORD=1
Environment=PAPER_UV_BIN=/root/.local/bin/uv
ExecStart=/srv/hermes-os/paper/scripts/paper-auto-research.sh
