[Unit]
Description=YALRU Paperclip real terminal - LazyCodex
After=network.target yalru-agent-cli.service

[Service]
Type=simple
Restart=always
RestartSec=2
ExecStart=/usr/bin/ttyd -i 127.0.0.1 -p 4291 -b /yalru-terminal/lazycodex -W -t disableLeaveAlert=true -t disableResizeOverlay=true -t titleFixed=LazyCodex /usr/local/bin/yalru-agent-terminal lazycodex

[Install]
WantedBy=multi-user.target
